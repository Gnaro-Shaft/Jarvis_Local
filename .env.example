# Jarvis — configuration locale.
# Copie ce fichier en `.env` (non versionné) et adapte à ta machine :
#     cp .env.example .env
# Toute variable déjà définie dans l'environnement a la priorité sur le .env.

# --- Serveur distant (agents Infra & Workspace, accès SSH) ---
# Hôte SSH de ton serveur (vide = pas de serveur). Doit être joignable sans mot de passe.
JARVIS_REMOTE_HOST=
# Racines où chercher les projets sur le serveur (séparées par :)
JARVIS_REMOTE_ROOTS=$HOME:$HOME/projects:/data
# Hôtes autorisés pour les commandes correctives (localhost + l'hôte distant sont ajoutés d'office)
JARVIS_ALLOWED_HOSTS=

# --- Projets locaux (agent Workspace), séparés par : (défaut: ton dossier perso) ---
JARVIS_PROJECT_ROOTS=

# --- Zones d'écriture autorisées (safe_fs / agent Obsidian), séparées par : ---
# ex. /chemin/vault-obsidian:/chemin/projets  (défaut: ce repo + ~/Downloads)
JARVIS_WORKSPACES=

# --- RAG Obsidian (Mnemo) ---
MNEMO_MCP_URL=http://localhost:8001/mcp

# --- Modèles Ollama ---
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:32b
DEV_MODEL=qwen3-coder:30b
INFRA_MODEL=qwen3:32b
ROUTER_MODEL=qwen3:4b
# Forcer UN seul modèle pour tous les agents (réactivité, évite les rechargements) :
# JARVIS_MODEL=qwen2.5:14b-instruct-q5_K_M
# JARVIS_KEEP_ALIVE=30m

# --- Accès web distant (server.py) ---
# JARVIS_BIND=<ip-tailscale-du-mac>
# JARVIS_TOKEN=<un-secret>
